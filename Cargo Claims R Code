clean_id_pattern <- function(x, pattern) {
  x <- as.character(x)
  x <- str_replace_all(x, "[\u00A0]", " ")
  x <- str_squish(x)
  str_extract(x, pattern)
}

audit_change <- function(before, after, label) {
  n_total   <- length(before)
  n_changed <- sum(!is.na(before) & before != after, na.rm = TRUE)
  n_now_na  <- sum(!is.na(before) & is.na(after))
  cat("\n--- ID clean audit:", label, "---\n")
  cat("Total rows:", n_total, "\n")
  cat("Changed values:", n_changed, "\n")
  cat("Became NA (no pattern match):", n_now_na, "\n")
}

clean_alpha_label <- function(x) {
  x <- as.character(x)
  x <- str_replace_all(x, "[\u00A0]", " ")
  x <- str_squish(x)
  x <- str_to_lower(x)
  x <- str_extract(x, "^[a-z ]+")
  str_squish(x)
}

clean_container_label <- function(x) {
  x <- as.character(x)
  x <- str_replace_all(x, "[\u00A0]", " ")
  x <- str_squish(x)
  x <- str_replace(x, "_.*$", "")
  x <- str_replace(x, "[^A-Za-z \\-].*$", "")
  str_squish(x)
}

