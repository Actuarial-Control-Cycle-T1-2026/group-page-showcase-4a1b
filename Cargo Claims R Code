### --------------------------------
### Score scenarios
### --------------------------------
score_scenario <- function(df) {
  lambda <- predict(freq_nb, newdata = df, type = "response")
  log_pred <- predict(sev_lognorm, newdata = df)
  sigma2 <- summary(sev_lognorm)$sigma^2
  mu <- exp(log_pred + 0.5 * sigma2)
  
  data.frame(
    lambda_hat = lambda,
    mu_hat = mu,
    pure_premium = lambda * mu
  )
}

scenario_results <- lapply(names(scenario_list), function(nm) {
  out <- score_scenario(scenario_list[[nm]])
  out$scenario <- nm
  out
}) %>%
  bind_rows() %>%
  dplyr::select(scenario, lambda_hat, mu_hat, pure_premium)

cat("\n--- Scenario Results ---\n")
print(scenario_results)

