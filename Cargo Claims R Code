### --------------------------------
### Faster aggregate simulation helper
### --------------------------------
simulate_aggregate_cost <- function(
    lambda_vec,
    mu_vec,
    theta,
    sigma_lognorm,
    years = 1,
    n_sims = 10000,
    freq_multiplier = 1,
    sev_multiplier = 1,
    seed = 123
) {
  set.seed(seed)
  
  out <- numeric(n_sims)
  
  for (s in seq_len(n_sims)) {
    sim_counts <- rnbinom(
      n = length(lambda_vec),
      mu = lambda_vec * years * freq_multiplier,
      size = theta
    )
    
    total_loss <- 0
    
    idx <- which(sim_counts > 0)
    
    if (length(idx) > 0) {
      for (i in idx) {
        n_i <- sim_counts[i]
        meanlog_i <- log(mu_vec[i] * sev_multiplier) - 0.5 * sigma_lognorm^2
        sim_sev <- rlnorm(n_i, meanlog = meanlog_i, sdlog = sigma_lognorm)
        total_loss <- total_loss + sum(sim_sev)
      }
    }
    
    out[s] <- total_loss
  }
  
  out
}

### --------------------------------
### Run stress scenarios
### --------------------------------
stress_results <- lapply(seq_len(nrow(stress_assumptions)), function(i) {
  sc <- stress_assumptions[i, ]
  
  sim_short <- simulate_aggregate_cost(
    lambda_vec = pricing_data$lambda_hat,
    mu_vec = pricing_data$mu_hat_lognorm,
    theta = freq_nb$theta,
    sigma_lognorm = summary(sev_lognorm)$sigma,
    years = 1,
    n_sims = 10000,
    freq_multiplier = sc$freq_multiplier,
    sev_multiplier = sc$sev_multiplier,
    seed = 100 + i
  )
  
  data.frame(
    scenario = sc$scenario,
    mean_cost = mean(sim_short),
    sd_cost = sd(sim_short),
    p95_cost = quantile(sim_short, 0.95),
    p99_cost = quantile(sim_short, 0.99),
    p999_cost = quantile(sim_short, 0.999)
  )
}) %>%
  bind_rows()

