## Frequency by Hazard Variables
make_qbin <- function(x, k = 5) {
  qs <- quantile(x, probs = seq(0, 1, length.out = k + 1), na.rm = TRUE)
  qs <- unique(qs)
  if (length(qs) < 3) return(rep(NA, length(x)))
  cut(x, breaks = qs, include.lowest = TRUE, right = TRUE)
}

