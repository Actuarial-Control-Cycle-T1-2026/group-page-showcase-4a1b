  data.frame(
    deductible = ded,
    limit = lim,
    mean_pure_premium = mean(adj_pp, na.rm = TRUE),
    p95_pure_premium = quantile(adj_pp, 0.95, na.rm = TRUE),
    p99_pure_premium = quantile(adj_pp, 0.99, na.rm = TRUE)
  )
}) %>%
  bind_rows()

