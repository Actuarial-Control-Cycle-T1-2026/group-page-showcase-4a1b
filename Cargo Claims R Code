##### 5) Aggregate Loss Simulation
##### Preferred final  model: Negative Binomial + Lognormal
##### ================================================================================================================

set.seed(123)

n_sims <- 5000
aggregate_costs_short <- numeric(n_sims)
aggregate_costs_long  <- numeric(n_sims)

### Lognormal residual standard deviation
sigma_lognorm <- summary(sev_lognorm)$sigma

for (s in 1:n_sims) {
  
  ### ------------------------------
  ### Short-term simulation
  ### ------------------------------
  sim_counts_short <- rnbinom(
    n = nrow(pricing_data),
    mu = pricing_data$lambda_hat * short_term_years,
    size = freq_nb$theta
  )
  
  sim_loss_short <- 0
  
  for (i in seq_along(sim_counts_short)) {
    n_i <- sim_counts_short[i]
    
    if (n_i > 0) {
      meanlog_i <- log(pricing_data$mu_hat_lognorm[i]) - 0.5 * sigma_lognorm^2
      sim_sev <- rlnorm(n_i, meanlog = meanlog_i, sdlog = sigma_lognorm)
      sim_loss_short <- sim_loss_short + sum(sim_sev)
    }
  }
  
  aggregate_costs_short[s] <- sim_loss_short
  
  ### ------------------------------
  ### Long-term simulation
  ### ------------------------------
  sim_counts_long <- rnbinom(
    n = nrow(pricing_data),
    mu = pricing_data$lambda_hat * long_term_years,
    size = freq_nb$theta
  )
  
  sim_loss_long <- 0
  
  for (i in seq_along(sim_counts_long)) {
    n_i <- sim_counts_long[i]
    
    if (n_i > 0) {
      meanlog_i <- log(pricing_data$mu_hat_lognorm[i]) - 0.5 * sigma_lognorm^2
      sim_sev <- rlnorm(n_i, meanlog = meanlog_i, sdlog = sigma_lognorm)
      sim_loss_long <- sim_loss_long + sum(sim_sev)
    }
  }
  
  aggregate_costs_long[s] <- sim_loss_long
}

