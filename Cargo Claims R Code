# Bucket into 5 quantile bins and summarise
summarise_freq_bucket <- function(df, var, k = 5) {
  x <- df[[var]]
  out <- df %>%
    mutate(bucket = make_qbin(x, k = k)) %>%
    filter(!is.na(bucket)) %>%
    group_by(bucket) %>%
    summarise(
      mean_claims = mean(claim_count),
      zero_rate   = mean(claim_count == 0),
      mean_rate   = mean(claim_count / exposure),
      n = n(),
      .groups = "drop"
    )
  out$variable <- var
  out
}

