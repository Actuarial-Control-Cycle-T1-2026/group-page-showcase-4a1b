# Flag NAs and out-of-range values for each variable
freq_flagged <- freq %>%
  mutate(
    bad_policy_id         = is.na(policy_id),
    bad_shipment_id       = is.na(shipment_id),
    
    # Data dictionary enforced strictly
    bad_cargo_value       = is.na(cargo_value)      | cargo_value < 50000      | cargo_value > 680000000,
    bad_weight            = is.na(weight)           | weight < 1500            | weight > 250000,
    bad_route_risk        = is.na(route_risk)       | !(route_risk %in% 1:5),
    bad_distance          = is.na(distance)         | distance < 1             | distance > 100,
    bad_transit_duration  = is.na(transit_duration) | transit_duration < 1     | transit_duration > 60,
    bad_pilot_experience  = is.na(pilot_experience) | pilot_experience < 1     | pilot_experience > 30,
    bad_vessel_age        = is.na(vessel_age)       | vessel_age < 1           | vessel_age > 50,
    bad_container_type    = is.na(container_type),
    bad_solar_radiation   = is.na(solar_radiation)  | solar_radiation < 0      | solar_radiation > 1,
    bad_debris_density    = is.na(debris_density)   | debris_density < 0       | debris_density > 1,
    bad_exposure          = is.na(exposure)         | exposure <= 0            | exposure > 1,
    bad_claim_count       = is.na(claim_count)      | claim_count < 0          | claim_count > 5 | claim_count %% 1 != 0
  ) %>%
  mutate(
    any_bad = bad_policy_id | bad_shipment_id | bad_cargo_value | bad_weight |
      bad_route_risk | bad_distance | bad_transit_duration | bad_pilot_experience |
      bad_vessel_age | bad_container_type | bad_solar_radiation |
      bad_debris_density | bad_exposure | bad_claim_count
  )

