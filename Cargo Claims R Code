summarise_sev_bucket <- function(df, var, k = 5) {
  x <- df[[var]]
  out <- df %>%
    mutate(bucket = make_qbin(x, k = k)) %>%
    filter(!is.na(bucket)) %>%
    group_by(bucket) %>%
    summarise(
      mean_sev   = mean(claim_amount),
      median_sev = median(claim_amount),
      p95_sev    = quantile(claim_amount, 0.95),
      p99_sev    = quantile(claim_amount, 0.99),
      n = n(),
      .groups = "drop"
    )
  out$variable <- var
  out
}

